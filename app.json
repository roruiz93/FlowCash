{
  "expo": {
    "name": "FlowCash",
    "slug": "flowcash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "com.flowcash.app",
    "ios": {
      "icon": "./assets/logo.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.flowcash"
    },
    "android": {
      "icon": "./assets/logo.png",
      "googleServicesFile": "./google-services.json",
      "package": "com.flowcash.app",
      "versionCode": 1,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-sharing",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#0a0a0f"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a10948e8-5d14-4f8c-a869-672f1397d35b"
      }
    }
  }
}
